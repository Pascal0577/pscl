#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
# Compatibility with GCC 15 and later
sed -i '/long long t1;/,+1s/()/(...)/' configure
./configure --prefix=/usr \
    --enable-cxx     \
    --disable-static \
    --docdir=/usr/share/doc/gmp-6.3.0
