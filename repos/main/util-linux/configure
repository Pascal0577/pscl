#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
mkdir -pv "$DESTDIR/var/lib/hwclock"
./configure --bindir=/usr/bin     \
    --libdir=/usr/lib     \
    --runstatedir=/run    \
    --sbindir=/usr/sbin   \
    --disable-chfn-chsh   \
    --disable-login       \
    --disable-nologin     \
    --disable-su          \
    --disable-setpriv     \
    --disable-runuser     \
    --disable-pylibmount  \
    --disable-liblastlog2 \
    --disable-static      \
    --without-python      \
    ADJTIME_PATH=/var/lib/hwclock/adjtime \
    --docdir=/usr/share/doc/util-linux-2.41.1
