#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
echo depends bli part_gpt > grub-core/extra_deps.lst
./configure --prefix=/usr        \
    --sysconfdir=/etc    \
    --disable-efiemu     \
    --with-platform=efi  \
    --target=x86_64      \
    --disable-werror
