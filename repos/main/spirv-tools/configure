#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "Failed to cd: $source_dir"
mkdir build
cd build || exit 1
cmake -D CMAKE_INSTALL_PREFIX=/usr     \
    -D CMAKE_BUILD_TYPE=Release      \
    -D SPIRV_WERROR=OFF              \
    -D BUILD_SHARED_LIBS=ON          \
    -D SPIRV_TOOLS_BUILD_STATIC=OFF  \
    -D SPIRV-Headers_SOURCE_DIR=/usr \
    -G Ninja ..
