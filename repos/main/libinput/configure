#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "Failed to cd: $source_dir"
mkdir build
cd build || exit 1
meson setup ..                \
    --prefix=/usr             \
    --buildtype=release       \
    -D debug-gui=false        \
    -D tests=false            \
    -D libwacom=false         \
    -D udev-dir=/usr/lib/udev \
    -D documentation=false
