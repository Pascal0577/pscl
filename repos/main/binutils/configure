#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
mkdir build
cd build || return 1
../configure --prefix=/usr \
     --sysconfdir=/etc   \
     --enable-ld=default \
     --enable-plugins    \
     --enable-shared     \
     --disable-werror    \
     --enable-64-bit-bfd \
     --enable-new-dtags  \
     --with-system-zlib  \
     --enable-default-hash-style=gnu
