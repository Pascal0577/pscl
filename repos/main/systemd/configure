#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
sed -e 's/GROUP="render"/GROUP="video"/' \
    -e 's/GROUP="sgx", //'               \
    -i rules.d/50-udev-default.rules.in
mkdir -p build
cd build || true
meson setup ..                 \
    --prefix=/usr            \
    --buildtype=release      \
    -D default-dnssec=no     \
    -D firstboot=false       \
    -D install-tests=false   \
    -D ldconfig=false        \
    -D man=disabled          \
    -D sysusers=false        \
    -D rpmmacrosdir=no       \
    -D homed=disabled        \
    -D userdb=false          \
    -D mode=release          \
    -D pam=enabled           \
    -D pamconfdir=/etc/pam.d \
    -D dev-kvm-mode=0660     \
    -D nobody-group=nogroup  \
    -D sysupdate=disabled    \
    -D ukify=disabled        \
    -D docdir=/usr/share/doc/systemd-257.8
