#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "Failed to cd: $source_dir"
patch -Np1 -i "$PKGROOT/libtirpc-1.3.6-gcc15_fixes-1.patch"
./configure --prefix=/usr                                   \
        --sysconfdir=/etc                               \
        --disable-static                                \
        --disable-gssapi
