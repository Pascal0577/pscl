#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "Failed to cd: $source_dir"
sed -i '/v0/{n;s/new:/new:kb=^?:/}' termcap
printf '\tkbs=\\177,\n' >> terminfo
TERMINFO=/usr/share/terminfo \
./configure --prefix=/usr \
    --sysconfdir=/etc     \
    --localstatedir=/var  \
    --disable-static      \
    --with-app-defaults=/etc/X11/app-defaults
