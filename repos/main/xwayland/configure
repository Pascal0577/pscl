#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "Failed to cd: $source_dir"
sed -i '/install_man/,$d' meson.build
mkdir build
cd build || exit 1
meson setup ..                     \
    --prefix=/usr                  \
    --buildtype=release            \
    -D xkb_output_dir=/var/lib/xkb
