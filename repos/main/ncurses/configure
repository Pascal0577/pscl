#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
./configure --prefix=/usr           \
    --mandir=/usr/share/man \
    --with-shared           \
    --without-debug         \
    --without-normal        \
    --with-cxx-shared       \
    --enable-pc-files       \
    --with-pkg-config-libdir=/usr/lib/pkgconfig
