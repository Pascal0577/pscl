#!/bin/sh
set -e
cd "$SRCDIR"
cd "$source_dir" || log_error "In $package_name.build: Failed to cd to $source_dir"
mkdir build
cd build || true
../configure --prefix=/usr       \
     --sysconfdir=/etc   \
     --enable-elf-shlibs \
     --disable-libblkid  \
     --disable-libuuid   \
     --disable-uuidd     \
     --disable-fsck
